{
    "manifest_version": 3,
    "name": "YouTube Cinema Focus",
    "version": "0.1",
    "description": "Cinema-style blackout mode for YouTube. Only the video remains visible.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}